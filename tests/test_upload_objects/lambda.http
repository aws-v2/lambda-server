### Register Node.js Zip Function
### Note: This requires a zip file named 'function.zip' in http_tests/
### Containing 'index.js' and 'helper.js'
POST http://localhost:8089/api/v1/lambda/functions
Authorization: Bearer eyJhbGciOiJub25lIiwidHlwZSI6IkpXVCJ9.eyJ1c2VySWQiOiJmN2I4Y2FkZC05MmNiLTQ4MzAtYTU2NS1hMWM5MDM1OTdmYzYiLCJpYXQiOjE3MTE5OTY4MDB9.
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="name"

hello-zip
--boundary
Content-Disposition: form-data; name="type"

lambda
--boundary
Content-Disposition: form-data; name="image"

node:18-alpine
--boundary
Content-Disposition: form-data; name="execution.kind"

node
--boundary
Content-Disposition: form-data; name="resources.cpu"

1
--boundary
Content-Disposition: form-data; name="resources.memory"

128
--boundary
Content-Disposition: form-data; name="file"; filename="function.zip"
Content-Type: application/zip

< ./function.zip
--boundary--

### Invoke Node.js Zip Function
POST http://localhost:8089/api/v1/lambda/invoke
Authorization: Bearer eyJhbGciOiJub25lIiwidHlwZSI6IkpXVCJ9.eyJ1c2VySWQiOiJmN2I4Y2FkZC05MmNiLTQ4MzAtYTU2NS1hMWM5MDM1OTdmYzYiLCJpYXQiOjE3MTE5OTY4MDB9.
Content-Type: application/json

{
    "name": "hello-zip",
    "payload": {
        "name": "Lambda Master"
    }
}




