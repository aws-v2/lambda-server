# Lambda Service - Staging Environment Template
# Use this for local development against staging-like settings

APP_PROFILE=staging
SERVICE_NAME=lambda-service
PORT=8089

# Database (use localhost if tunneling or local instance)
DB_HOST=localhost
DB_PORT=5432
DB_USER=lambda-server
DB_PASSWORD=staging-password-change-me
DB_NAME=lambda_db
DB_SSLMODE=disable

# NATS
NATS_URL=nats://localhost:4222
NATS_USER=auth-server
NATS_PASSWORD=auth-secret

# Eureka & Discovery
EUREKA_SERVER_URL=http://localhost:8761/eureka

# AWS
AWS_REGION=eu-north-1
CODE_STORAGE_PATH=./storage
